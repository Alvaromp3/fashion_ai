flowchart TB
    %% ===== Presentation Tier =====
    subgraph T1["Presentation Tier"]
        B["Browser<br/>React SPA"]
    end

    %% ===== Application Tier =====
    subgraph T2["Application Tier"]
        API["Express API<br/>Node.js + Mongoose"]
    end

    %% ===== Data Tier =====
    subgraph T3["Data Tier"]
        DB[("MongoDB")]
        IS[("Image Storage<br/>Local / Cloudinary / R2")]
    end

    %% ===== External Services =====
    subgraph EXT["External Services"]
        A0["Auth0<br/>OAuth 2.0 / OIDC"]
        ML["Python Flask ML Service"]
        HF["Hugging Face Space<br/>ViT Hosting"]
        OR["OpenRouter<br/>GPT-4o-mini"]
    end

    %% Client to API
    B -->|"REST + JWT"| API

    %% Auth flow
    B -->|"OAuth login"| A0
    A0 -->|"JWT returned"| B
    API -->|"JWT validation<br/>(issuer / JWKS)"| A0

    %% Core backend flows
    API -->|"CRUD"| DB
    API -->|"Upload / Fetch"| IS

    %% ML flow
    API -->|"POST /classify-vit"| ML
    HF -.->|"Hosts ViT model<br/>used by ML service"| ML

    %% LLM flow
    API -->|"POST /chat/completions"| OR

    %% ===== Colors =====
    classDef presentation fill:#dbeafe,stroke:#1d4ed8,color:#111827,stroke-width:2px;
    classDef application fill:#dcfce7,stroke:#15803d,color:#111827,stroke-width:2px;
    classDef data fill:#fef3c7,stroke:#d97706,color:#111827,stroke-width:2px;
    classDef external fill:#f3e8ff,stroke:#7e22ce,color:#111827,stroke-width:2px;
    classDef storage fill:#fde68a,stroke:#b45309,color:#111827,stroke-width:2px;

    class B presentation;
    class API application;
    class DB,IS storage;
    class A0,ML,HF,OR external;
